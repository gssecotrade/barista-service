generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BaristaUser {
  id                String           @id @default(cuid())
  externalUserId    String           @unique
  shopifyCustomerId String?
  email             String?
  firstSeenAt       DateTime         @default(now())
  lastSeenAt        DateTime         @updatedAt
  conversationId    String?
  profileSummary    String?

  profile           BaristaProfile?
  messages          BaristaMessage[]
  preferences       BaristaPreference[]

  @@map("User")
}

model BaristaProfile {
  id             String      @id @default(cuid())
  userId         String      @unique
  lastIntent     String?
  favoriteCoffee String?
  preferences    Json?
  state          Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           BaristaUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BaristaMessage {
  id        String      @id @default(cuid())
  userId    String
  role      String
  content   String
  meta      Json?
  createdAt DateTime    @default(now())

  user      BaristaUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Message")
}

model BaristaPreference {
  id        String      @id @default(cuid())
  userId    String
  key       String
  value     String
  createdAt DateTime    @default(now())

  user      BaristaUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Preference")
}
